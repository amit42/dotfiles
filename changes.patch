+        if is_empty or is_dir or is_tree then
+          if is_dir then vim.cmd("cd " .. vim.fn.fnameescape(bufname)) end
+          pcall(vim.cmd, "NvimTreeClose")
+          require("user.dashboard").open()
+        end
+      end, 100)
+    end,
+  })
