+      vim.defer_fn(function()
+        local ft      = vim.bo.filetype
+        local bufname = vim.api.nvim_buf_get_name(0)
+        local is_empty = bufname == "" and (ft == "" or ft == "dashboard")
+        local is_dir   = vim.fn.isdirectory(bufname) == 1
+        local is_tree  = ft == "NvimTree"
