+  -- Hide trailing slash on directory entries in telescope file browser.
+  -- The file browser appends "/" to folder names; the folder icon already
+  -- signals "directory", so the slash is visual noise.  Conceal it without
+  -- touching the entry data (ordinal / path stay intact for navigation).
+  vim.api.nvim_create_autocmd("FileType", {
+    group = augroup("telescope_no_dir_slash"),
+    pattern = "TelescopeResults",
+    callback = function()
+      vim.opt_local.conceallevel  = 2
+      vim.opt_local.concealcursor = "nvc"
+      -- Match the slash that sits at EOL (possibly followed by padding spaces)
