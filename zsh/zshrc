# Fuzzy git log browser — preview full diff for each commit
# Usage: fglog → pick commit → prints SHA (pipe or use interactively)
fglog() {
  git log --oneline --color=always | \
    fzf --ansi --preview 'git show --color=always {1}' \
        --preview-window=right:60% | \
    awk '{print $1}'
}

# Fuzzy cd — jump into any subdirectory from current location
# Usage: fcd → pick dir → cd into it
fcd() {
  local dir
  dir=$(fd --type d --hidden --exclude .git | \
    fzf --preview 'eza --tree --level=1 --icons {}') && cd "$dir"
}

# Fuzzy kill — list processes, pick one, kill -9 it
# Usage: fkill → pick process → killed
fkill() {
  local pid
  pid=$(ps aux | fzf --header='Select process to kill' | awk '{print $2}')
  [[ -n "$pid" ]] && kill -9 "$pid" && echo "Killed $pid"
}

