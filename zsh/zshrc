# gotf — run tests matching a specific name pattern.
# Uses -run which accepts a regexp, so gotf "TestFoo" matches TestFoo,
# TestFooBar, TestFooWithEdgeCase, etc.
# Usage: gotf TestMyFunc
#        gotf "TestParser.*"
gotf() { go test -v -run "$1" ./...; }

# gocover — run tests with coverage and open the HTML report in a browser.
# The report shows which lines were/weren't hit and the overall %.
# Coverage profile is written to /tmp so it doesn't clutter the project.
gocover() {
  go test -coverprofile=/tmp/go-cover.out ./... && \
  go tool cover -html=/tmp/go-cover.out
}

# godeps — print the module dependency graph as a simple arrow list.
# Requires graphviz for dot rendering but this version just prints text.
# Usage: godeps | head -20    — see direct dependencies only
godeps() { go mod graph | awk '{print $1, "->", $2}' | head -50; }


