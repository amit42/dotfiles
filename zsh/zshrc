# TMUX
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# tmux sessions persist after terminal close. Always work inside a
# session so you never lose running processes to window accidents.

# tq — detach from the current tmux session without killing it.
# The session stays alive in the background; re-attach with ts or tn.
alias tq='tmux detach'

# tkill — kill the current tmux session entirely.
# All windows and panes in the session are destroyed.
alias tkill='tmux kill-session'

# ts — attach to a session named after the current directory, or create
# a new one with 3 pre-configured windows:
#   1. editor  — opens nvim in project root
#   2. terminal — plain shell for running commands
#   3. logs    — dedicated pane for tailing logs / lnav
# If the session already exists, just attach (windows are left as-is).
# Usage: ts    — from ~/dev/myproject creates/attaches session "myproject"
ts() {
  local name
  name="$(basename "$PWD")"
  if tmux has-session -t "$name" 2>/dev/null; then
    tmux attach-session -t "$name"
  else
    tmux new-session  -d -s "$name" -c "$PWD" -n "editor"   \; \
      send-keys        "nvim ." Enter                         \; \
      new-window      -n "terminal" -c "$PWD"                \; \
      new-window      -n "logs"     -c "$PWD"                \; \
      select-window   -t "$name:editor"                      \; \
      attach-session  -t "$name"
  fi
}

# clast — copy the output of the last command to the clipboard.
# Uses a preexec hook to record the cursor row just before each command
# runs, then captures the tmux pane content between that row and the
# current cursor position (i.e. exactly the output, no prompt lines).
#
# Limitation: only works for output that fits in the visible pane.
# For output that scrolled off, use tmux copy mode (prefix + [).
# Only works inside a tmux session.
#
# Usage: clast          — copies last command's output
#        clast | wc -l  — pipe the output instead
_clast_row=0
_clast_preexec() { _clast_row=$(tmux display-message -p '#{cursor_y}' 2>/dev/null || echo 0); }
add-zsh-hook preexec _clast_preexec

clast() {
  if [[ -z "$TMUX" ]]; then
    echo "Not in tmux. Next time: cmd | cpy"
    return 1
  fi
  local cur=$(tmux display-message -p '#{cursor_y}')
  local sed_start=$(( _clast_row + 2 ))   # skip the command line itself (1-indexed)
  local sed_end=$(( cur ))                 # stop before the new prompt line
  if (( sed_end < sed_start )); then
    echo "No output captured."
    return 1
  fi
  local out
  out=$(tmux capture-pane -p | sed -n "${sed_start},${sed_end}p")
  echo "$out" | pbcopy
  echo "Copied $(( sed_end - sed_start + 1 )) lines."
}

# tls — list all tmux sessions with their window count and status.
alias tls='tmux list-sessions 2>/dev/null || echo "No tmux sessions running."'

# tswitch — fzf picker to jump between tmux sessions.
# Press Enter on a session name to switch to it.
# Usage: tswitch
tswitch() {
  local session
  session=$(tmux list-sessions -F '#{session_name}' 2>/dev/null \
    | fzf --prompt='tmux session> ' --height=10 --reverse)
  [[ -n "$session" ]] && tmux switch-client -t "$session"
}

# tn — attach to or create a named tmux session.
# Usage: tn work       tn dotfiles       tn scratch
tn() {
  [[ -z "$1" ]] && { echo "Usage: tn <name>"; return 1; }
  tmux new-session -A -s "$1"
}

# zshr — reload the zshrc in the current shell without opening a new one.
