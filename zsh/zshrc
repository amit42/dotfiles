# mise — universal runtime version manager.
# Single replacement for pyenv, nvm, goenv, rbenv, sdkman, etc.
# Reads .mise.toml or .tool-versions files in each project directory
# and activates the correct runtime version automatically on cd.
# Global defaults: mise use --global node@lts python@3.12
# Per-project: cd myproject && mise use node@20 python@3.11
# List installed: mise ls
# Install: brew install mise
if command -v mise &>/dev/null; then
  eval "$(mise activate zsh)"
fi

# yazi — terminal file manager with shell cd-on-quit integration.
# The `ya` wrapper saves the last directory yazi was in when you quit,
# then cd's the shell into it. This makes yazi a full navigation tool,
# not just a viewer. Use it as a visual alternative to fcd.
#
# Keybindings inside yazi:
#   h / l       — navigate into/out of directory
#   j / k       — move selection up/down
#   Enter       — open file with default handler
#   y           — yank (copy) selected file
#   p           — paste
#   d           — move to trash
#   /           — search by filename
#   q           — quit (and cd to current dir)
# Install: brew install yazi
if command -v yazi &>/dev/null; then
  ya() {
    local tmp cwd
    tmp=$(mktemp -t "yazi-cwd.XXXXXX")
    yazi "$@" --cwd-file="$tmp"
    cwd=$(cat -- "$tmp")
    [[ -n "$cwd" && "$cwd" != "$PWD" ]] && cd "$cwd"
    rm -f -- "$tmp"
  }
fi

# navi — interactive cheatsheet and snippet tool.
# Press Ctrl+G at any point to open a fuzzy-searchable list of commands
# with descriptions and variable placeholders. Select one and navi
# inserts it at the cursor with placeholders highlighted for editing.
# Add community cheatsheets: navi repo add denisidoro/cheats
# Add your own:              navi repo add <github-user>/<repo>
