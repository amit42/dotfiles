mkcd() { mkdir -p "$1" && cd "$1"; }

# Backup file with timestamp — non-destructive
# Usage: backup config.yaml  →  config.yaml.bak.20260405_143000
backup() { cp "$1" "${1}.bak.$(date +%Y%m%d_%H%M%S)"; }

# Universal archive extractor — handles any format
# Usage: extract archive.tar.gz
extract() {
  case "$1" in
    *.tar.bz2) tar xjf "$1"   ;;
    *.tar.gz)  tar xzf "$1"   ;;
    *.tar.xz)  tar xJf "$1"   ;;
    *.tar)     tar xf  "$1"   ;;
    *.bz2)     bunzip2 "$1"   ;;
    *.gz)      gunzip  "$1"   ;;
    *.zip)     unzip   "$1"   ;;
    *.7z)      7z x    "$1"   ;;
    *.rar)     unrar x "$1"   ;;
    *)         echo "Unknown archive format: $1" ;;
  esac
}

# Show which process is using a port
# Usage: whichport 8080
whichport() { lsof -i ":$1"; }

# Pretty-print JSON in nvim with syntax highlighting
# Usage: json '{"key": "value"}'  or  curl ... | json
json() {
  if [[ -t 0 ]]; then
    echo "$1" | python3 -m json.tool | nvim -c 'set ft=json' -
  else
    python3 -m json.tool | nvim -c 'set ft=json' -
  fi
}

# Spin up a quick HTTP server in the current directory
# Usage: serve        →  http://localhost:8000
#        serve 3000   →  http://localhost:3000
serve() { python3 -m http.server "${1:-8000}"; }

# Weather in terminal
# Usage: weather          →  local weather
#        weather London   →  weather for London
weather() { curl "wttr.in/${1:-}"; }

# Compile and run a single C file (no Makefile needed)
# Usage: crun main.c
crun() { gcc -o /tmp/crun "$1" && /tmp/crun; }

# Print sizeof a C type — useful for embedded work
# Usage: csizeof uint32_t
csizeof() {
  printf '#include <stdio.h>\n#include <stdint.h>\nint main(){printf("%%zu\\n",sizeof(%s));}' "$1" \
    | gcc -x c - -o /tmp/csizeof && /tmp/csizeof
}

# Show the 20 largest files under current directory
bigfiles() { du -ah . | sort -rh | head -20; }

# git clone + immediately cd into the repo
# Usage: gclone https://github.com/user/repo
gclone() { git clone "$1" && cd "$(basename "$1" .git)"; }

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PROMPT POSITIONING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Ctrl+L — push prompt to middle of terminal instead of full clear.
# Previous output stays in scrollback (scroll up to see it).
# Prompt lands at vertical center so you have breathing room.
_prompt_to_middle() {
  local half=$(( LINES / 2 ))
  printf '\n%.0s' {1..$half}
  zle reset-prompt
}
zle -N _prompt_to_middle
bindkey '^L' _prompt_to_middle

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LOG VIEWING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# lnav — Log file Navigator. Auto-detects log format (syslog, nginx,
# apache, json, journald) and renders with syntax highlighting.
# Supports filtering, regex search, SQL queries, and multi-file tailing.
# Only needs to be installed LOCALLY — remote server just runs tail -f.
#
# Local usage:
#   log /var/log/nginx/access.log   →  open in lnav TUI
#   log *.log                       →  tail multiple files together
#   journalctl -f | lnav            →  live systemd journal
#
# lnav keybindings (inside TUI):
#   /        →  regex search
#   ;        →  SQL query mode (SELECT * FROM log WHERE ...)
#   :filter-in <pattern>   →  only show matching lines
#   :filter-out <pattern>  →  hide matching lines
#   q        →  quit

if command -v lnav &>/dev/null; then
  alias log='lnav'
else
  # Fall back to bat syntax highlighting for local log files
  alias log='bat --paging=never --language=log'
fi

# sshlog — tail a remote log file with local lnav rendering
# The remote server only needs to run `tail -f`, no lnav needed there.
# Usage: sshlog user@server /var/log/nginx/access.log
#        sshlog prod-web /var/log/app/error.log
sshlog() {
  if [[ $# -lt 2 ]]; then
    echo "Usage: sshlog <host> <logfile>"
    return 1
  fi
  ssh "$1" "tail -f $2" | lnav
}

# sshcat — view a remote log file once (no follow) with bat highlighting
# Useful for inspecting archived logs without a full TUI session.
# Usage: sshcat user@server /var/log/syslog
#        sshcat prod-db /var/log/postgresql/postgresql.log
sshcat() {
  if [[ $# -lt 2 ]]; then
    echo "Usage: sshcat <host> <logfile>"
    return 1
  fi
  ssh "$1" "cat $2" | bat --language=log
}

# sshj — tail remote systemd journal with lnav rendering
# Usage: sshj user@server               →  all journal entries
#        sshj user@server nginx         →  journal for specific unit
sshj() {
  if [[ $# -lt 1 ]]; then
    echo "Usage: sshj <host> [unit]"
    return 1
  fi
  local unit_filter=""
  [[ -n "$2" ]] && unit_filter="-u $2"
  ssh "$1" "journalctl -f $unit_filter" | lnav
}

