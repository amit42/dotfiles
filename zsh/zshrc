# venv workflow — prefer uv (10–100× faster) if installed, else stdlib.
# venv — create a .venv in the current directory (doesn't activate)
# va   — activate an existing .venv
# vd   — deactivate the current venv
alias venv='python3 -m venv .venv'  # create venv (use mkvenv to also activate)
alias va='source .venv/bin/activate' # activate .venv in current dir
alias vd='deactivate'                # deactivate current venv

# mkvenv — create a venv AND activate it in one step.
# Prefers uv (much faster, handles Python version selection) and
# falls back to the stdlib venv module if uv isn't installed.
mkvenv() {
  if command -v uv &>/dev/null; then
    uv venv .venv && source .venv/bin/activate
  else
    python3 -m venv .venv && source .venv/bin/activate
  fi
}

# pyclean — remove all __pycache__ directories and .pyc files recursively.
# Run before committing or archiving a project to keep the tree clean.
# The `2>/dev/null` on the first find suppresses errors when it tries to
# recurse into directories it already deleted.
pyclean() {
  find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null
  find . -name "*.pyc" -delete
  echo "Cleaned."
}

# pyreqs — freeze the current virtualenv into requirements.txt.
# Usage: activate your venv, then run `pyreqs` to capture a snapshot.
pyreqs() { pip freeze > requirements.txt && echo "Saved to requirements.txt"; }

# repl — open an interactive Python REPL.
# Uses ptpython (brew install ptpython) if available — it adds syntax
# highlighting, multi-line editing, and history to the standard REPL.
alias repl='command -v ptpython &>/dev/null && ptpython || python3'


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ALIASES: UV  (fast Python package / project manager)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# uv is a Rust-based drop-in replacement for pip, pip-tools, pipx,
# venv, and parts of poetry. It's 10–100× faster than pip.
#
# Two usage modes:
#   pip mode  — uv pip install / uv venv (compatible with requirements.txt)
#   project mode — uv init / uv add / uv sync (uses pyproject.toml + lockfile)
#
# Install: curl -LsSf https://astral.sh/uv/install.sh | sh
# Docs:    https://docs.astral.sh/uv/
if command -v uv &>/dev/null; then
  alias uvi='uv pip install'         # install a package into current venv
  alias uvid='uv add --dev'          # add a dev dependency (project mode, pyproject.toml)
  alias uva='uv add'                 # add a runtime dependency (project mode)
  alias uvr='uv remove'              # remove a dependency
  alias uvs='uv sync'                # sync venv to match lockfile exactly
  alias uvrun='uv run'               # run a command inside the project venv: uvrun pytest
  alias uvvenv='uv venv'             # create a venv (faster than python -m venv)
  alias uvlock='uv lock'             # regenerate uv.lock from pyproject.toml
  alias uvup='uv pip install --upgrade'  # upgrade a specific package
  alias uvupall='uv pip install --upgrade $(uv pip list --format=freeze | cut -d= -f1 | tr "\n" " ")'
  alias uvx='uvx'                    # run a tool ephemerally without installing: uvx ruff check .
  alias uvinit='uv init'             # scaffold a new project with pyproject.toml
  alias uvtree='uv pip tree'         # show full dependency tree of current venv
fi


