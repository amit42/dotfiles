# ELITE TOOLS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# zoxide — smarter cd that learns your most-visited directories
# After a few days of use, `z proj` jumps to ~/dev/my-project
# `cd` is aliased to `z` so existing muscle memory still works
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh)"
  alias cd='z'
fi

# direnv — loads/unloads env vars when you enter/leave a directory
# Create a .envrc file in any project: echo 'export API_KEY=...' > .envrc
# then `direnv allow` — vars load on cd in, unload on cd out
if command -v direnv &>/dev/null; then
  eval "$(direnv hook zsh)"
fi

# thefuck — press Esc twice to correct your last command
# e.g. `got test` → suggest `go test`
if command -v thefuck &>/dev/null; then
  eval "$(thefuck --alias)"
fi

# atuin — replaces Ctrl+R with a beautiful searchable history
# Syncs history across machines if you set up an atuin account
# Ctrl+R → full-screen history search with timestamps and exit codes
if command -v atuin &>/dev/null; then
  eval "$(atuin init zsh)"
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AUTO TMUX
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# On every new terminal: attach to session 'main' or create it.
# Skipped if:
#   - already inside tmux ($TMUX is set)
#   - non-interactive shell (scripts, CI)
#   - stdin is not a terminal
if command -v tmux &>/dev/null && [[ -z "$TMUX" ]] && [[ -t 0 ]]; then
  tmux attach -t main 2>/dev/null || tmux new-session -s main
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# STARSHIP PROMPT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Config: dotfiles/zsh/starship.toml → deployed to ~/.config/starship.toml
# To change prompt: edit starship.toml, run bash install.sh, open new terminal.
# Docs: https://starship.rs/config/
if command -v starship &>/dev/null; then
  eval "$(starship init zsh)"
else
  print -P "%F{yellow}⚠ starship not found — run: brew install starship%f"
fi
