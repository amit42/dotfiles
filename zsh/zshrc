# DATA TOOLS: jq / yq
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# jq — command-line JSON processor.
# Install: brew install jq
# Full docs: https://jqlang.github.io/jq/manual/
#
# Common patterns:
#   curl api.example.com/users | jqp          — pretty-print response
#   cat data.json | jq '.users[].name'         — extract a field
#   cat data.json | jq 'select(.age > 30)'     — filter by condition
#   cat data.json | jq '{name, email}'         — project specific keys
if command -v jq &>/dev/null; then
  alias jqp='jq .'                  # pretty-print: echo '{"a":1}' | jqp
  alias jqk='jq "keys[]"'           # list top-level keys of an object
  alias jql='jq "length"'           # array length or object key count

  # jqb — pretty-print JSON with bat syntax highlighting.
  # Useful for large payloads where you want colour in the pager.
  # The filter arg defaults to . (identity) if not provided.
  # Usage: curl api.example.com | jqb
  #        jqb '.users' data.json
  jqb() { jq -C "${1:-.}" | bat --language=json --paging=never; }

  # jqf — fuzzy-search all key paths in a JSON file.
  # Shows every dot-notation path (e.g. users.0.address.city) in fzf,
  # then evaluates the selected path and prints its value.
  # Usage: jqf data.json
  #        curl api.example.com | jqf    (reads from stdin with -)
  jqf() {
    local file="${1:--}"
    jq -r 'paths | join(".")' "$file" 2>/dev/null | \
      fzf --prompt='jq path> ' | \
      xargs -I{} jq ".{}" "$file"
  }
fi

# yq — YAML, JSON, and TOML processor with jq-compatible syntax.
# Install: brew install yq
# Full docs: https://mikefarah.gitbook.io/yq/
#
# Common patterns:
#   yqp config.yaml                        — pretty-print YAML
#   yq '.spec.replicas' deployment.yaml    — extract a value
#   yq '.spec.replicas = 3' deployment.yaml — set a value (in-place with -i)
#   cat config.yaml | yqj                  — convert YAML to JSON
if command -v yq &>/dev/null; then
  alias yqp='yq .'          # pretty-print YAML: cat config.yaml | yqp
  alias yqj='yq -o=json .'  # convert YAML → JSON: cat values.yaml | yqj
  alias yqy='yq -o=yaml .'  # convert JSON → YAML: cat data.json | yqy
fi


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# BENCHMARKING / CODE TOOLS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# hyperfine — statistical command-line benchmarking.
# Runs each command multiple times, warms up the cache, and reports
# mean / stddev / min / max with a comparison table.
# Install: brew install hyperfine
# Usage: bench 'ls'                               — single command
#        bench 'ls' 'eza'                         — compare two commands
#        bench --warmup 5 'grep foo large.log'    — 5 warmup runs first
#        bench --export-json results.json 'cmd'   — save results
command -v hyperfine &>/dev/null && alias bench='hyperfine'

# tokei — count lines of code, broken down by language.
# Much faster than cloc. Skips .gitignore'd files automatically.
# Install: brew install tokei
# Usage: cloc                — summary for current project
#        cloc src/           — specific directory
#        cloc --sort lines   — sort by line count
command -v tokei &>/dev/null && alias cloc='tokei'

# just — modern task runner, Makefile replacement.
# Recipes are defined in a `justfile` in the project root.
# Advantages over make: no tab-indentation requirement, better error
# messages, shell choice per recipe, and no implicit file targets.
# Install: brew install just
# Usage: j           — run default recipe
#        jl          — list all recipes with descriptions
#        j test      — run the 'test' recipe
#        j deploy prod — run 'deploy' with argument
if command -v just &>/dev/null; then
  alias j='just'
  alias jl='just --list'
fi

# zsh_time — measure real shell startup time (time-to-prompt).
#
# IMPORTANT: `zsh -i -c exit` is a misleading benchmark — it forces
# zinit's async (wait lucid) plugins to fully load before exit, adding
# several seconds that you never experience in real usage. The correct
# measure is `zsh -c 'source ~/.zshrc'` which times only the synchronous
# startup path — exactly what blocks the prompt from appearing.
#
# Run zsh_time after adding new plugins or evals to catch regressions.
# Usage: zsh_time
zsh_time() {
  local cmd='source ~/.zshrc'
  if command -v hyperfine &>/dev/null; then
    echo "Measuring real startup (time-to-prompt)..."
    hyperfine --warmup 3 --runs 10 "zsh -c '$cmd'" 2>&1
    echo ""
    echo "For a detailed breakdown of which function is slow, run:"
    echo "  ZSH_PROFILE=1 zsh"
  else
    echo "Measuring real startup (time-to-prompt)..."
    for i in {1..5}; do /usr/bin/time zsh -c "$cmd" 2>&1; done
  fi
}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PRODUCTIVITY HACKS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ppath — print PATH entries one per line with line numbers.
# Makes it trivial to spot duplicates, wrong order, or missing entries.
# Usage: ppath
ppath() { echo "$PATH" | tr ':' '\n' | nl; }

# greph — search your shell history with fzf.
# More ergonomic than Ctrl+R when you want to scan visually,
# or Ctrl+R is taken by atuin but you want a quick plain grep.
# Usage: greph docker       greph "git commit"
greph() {
  history 1 | grep --color=always "${*:-}" | \
    fzf --ansi --tac --no-sort | awk '{$1=""; print substr($0,2)}'
}

# notify — send a macOS desktop notification when a long command finishes.
# Detects success vs failure from the exit code and plays a matching
# system sound. Chain after slow commands: sleep 60 && notify "backup done"
# Usage: make build && notify "build done"
#        notify "deploy finished"   (at end of any command chain)
notify() {
  local code=$?
  local msg="${*:-Done}"
  if [[ $code -eq 0 ]]; then
    osascript -e "display notification \"$msg\" with title \"✓ Success\" sound name \"Glass\""
  else
    osascript -e "display notification \"$msg (exit $code)\" with title \"✗ Failed\" sound name \"Basso\""
  fi
}

# epoch — print the current Unix timestamp.
# fromepoch — convert a Unix timestamp to a human-readable date.
# Usage: epoch                     → 1712345678
#        fromepoch 1712345678      → Tue Apr  5 22:54:38 IST 2026
epoch()     { date +%s; }
fromepoch() { date -r "$1"; }

# b64 / b64d — base64 encode / decode a string.
# Usage: b64 "hello world"         → aGVsbG8gd29ybGQ=
#        b64d "aGVsbG8gd29ybGQ="  → hello world
b64()  { echo -n "$1" | base64; }
b64d() { echo -n "$1" | base64 -d && echo; }

# urlencode / urldecode — percent-encode / decode a string.
# Usage: urlencode "hello world"     → hello%20world
#        urldecode "hello%20world"   → hello world
urlencode() { python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$1"; }
urldecode() { python3 -c "import urllib.parse,sys; print(urllib.parse.unquote(sys.argv[1]))" "$1"; }

# jwt — decode and pretty-print a JWT token's payload.
# Reads from argument or falls back to clipboard if no arg given.
# Does NOT verify the signature — for inspection only.
# Usage: jwt eyJhbGci...
#        jwt                        (decodes whatever is in clipboard)
jwt() {
  local token="${1:-$(pbpaste)}"
  echo "$token" | cut -d. -f2 | base64 -d 2>/dev/null | jq .
}

# sha256 / sha1 — file checksum shorthands.
# macOS uses `shasum` rather than `sha256sum` (Linux).
# Usage: sha256 firmware.bin        sha1 archive.tar.gz
sha256() { shasum -a 256 "$@"; }
sha1()   { shasum -a 1   "$@"; }

# sslcheck — show SSL certificate validity dates for a domain.
# Quick way to see when a cert expires without opening a browser.
# Usage: sslcheck github.com        sslcheck api.example.com
sslcheck() {
  echo | openssl s_client -servername "$1" -connect "$1:443" 2>/dev/null \
    | openssl x509 -noout -subject -dates
}

# headers — fetch and display HTTP response headers with bat highlighting.
# Usage: headers https://github.com
#        headers api.example.com/users
headers() { curl -sI "$1" | bat --language=http --paging=never; }

# isup — check whether a URL returns a successful HTTP status.
# Times out after 5 seconds so it doesn't hang on dead hosts.
# Usage: isup github.com            isup https://my-api.example.com/health
isup() {
  local code
  code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 "$1")
  [[ $code -lt 400 ]] \
    && echo "✓ $1 is up (HTTP $code)" \
    || echo "✗ $1 is down (HTTP $code)"
}

# countdown — count down N seconds with a live display.
# Optionally sends a macOS notification when it reaches zero.
# Usage: countdown 30               countdown 60 "build ready"
countdown() {
  local n="${1:-10}" msg="${2:-}"
  for ((i=n; i>=0; i--)); do
    printf "\r  %02d " "$i"
    sleep 1
  done
  echo ""
  [[ -n "$msg" ]] && notify "$msg"
}

# stopwatch — measure elapsed time between start and Enter key.
# Usage: stopwatch    (press Enter to stop)
stopwatch() {
  local start end
  start=$(date +%s)
  echo "Stopwatch started — press Enter to stop."
  read -r
  end=$(date +%s)
  printf "Elapsed: %ds\n" $((end - start))
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# UTILITY FUNCTIONS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# mkcd — create a directory and immediately cd into it.
# Equivalent to: mkdir -p foo && cd foo
# Usage: mkcd my-new-project
#        mkcd deep/nested/path
mkcd() { mkdir -p "$1" && cd "$1"; }

# backup — copy a file with a timestamped suffix.
# Non-destructive alternative to overwriting when testing config changes.
# The timestamp is YYYYmmdd_HHMMSS so backups sort chronologically.
# Usage: backup nginx.conf          → nginx.conf.bak.20260401_153000
#        backup ~/.zshrc            → ~/.zshrc.bak.20260401_153000
backup() { cp "$1" "${1}.bak.$(date +%Y%m%d_%H%M%S)"; }

# extract — universal archive extractor.
# When ouch is installed (see MODERN TOOL REPLACEMENTS) this function
# is overridden with ouch which handles even more formats automatically.
# This fallback handles the most common formats without any extra tools.
# Usage: extract archive.tar.gz
#        extract firmware.zip
extract() {
  case "$1" in
    *.tar.bz2) tar xjf "$1"   ;;
    *.tar.gz)  tar xzf "$1"   ;;
    *.tar.xz)  tar xJf "$1"   ;;
    *.tar)     tar xf  "$1"   ;;
    *.bz2)     bunzip2 "$1"   ;;
    *.gz)      gunzip  "$1"   ;;
    *.zip)     unzip   "$1"   ;;
    *.7z)      7z x    "$1"   ;;
    *.rar)     unrar x "$1"   ;;
    *)         echo "Unknown archive format: $1" ;;
  esac
}

# whichport — show which process is listening on a port.
# Uses lsof to inspect all open internet connections and filters
# by port number. Shows PID, command, and user.
# Usage: whichport 8080
#        whichport 5432     — check if postgres is running
whichport() { lsof -i ":$1"; }

# json — pretty-print and open JSON in nvim with syntax highlighting.
# Detects whether input is coming from a pipe (stdin) or as an argument.
# Usage: json '{"key": "value"}'
#        curl https://api.example.com/users | json
json() {
  if [[ -t 0 ]]; then
    echo "$1" | python3 -m json.tool | nvim -c 'set ft=json' -
  else
    python3 -m json.tool | nvim -c 'set ft=json' -
  fi
}

# serve — start a one-liner HTTP server in the current directory.
# Useful for testing static files, sharing a local directory over LAN,
# or previewing built HTML without a full dev server.
# Usage: serve           → http://localhost:8000
#        serve 3000      → http://localhost:3000
serve() { python3 -m http.server "${1:-8000}"; }

# weather — fetch a weather forecast in the terminal via wttr.in.
# wttr.in returns an ANSI-coloured 3-day forecast with icons.
# Usage: weather                — auto-detect location
#        weather London         — specific city
#        weather "New York"     — city with space
#        weather London?format=3 — one-line compact format
weather() { curl "wttr.in/${1:-}"; }

# crun — compile and run a single C source file without a Makefile.
# Useful for quick experiments or testing a snippet in isolation.
# Binary is written to /tmp so it doesn't clutter the working directory.
# Usage: crun main.c
#        crun experiment.c
crun() { gcc -o /tmp/crun "$1" && /tmp/crun; }

# csizeof — print the size in bytes of a C type.
# Writes, compiles, and runs a minimal C program on-the-fly.
# Particularly useful in embedded work where sizeof matters for
# packing structs and mapping memory-mapped register layouts.
# Usage: csizeof uint32_t    → 4
#        csizeof "struct { char a; int b; }"    → shows padding
csizeof() {
  printf '#include <stdio.h>\n#include <stdint.h>\nint main(){printf("%%zu\\n",sizeof(%s));}' "$1" \
    | gcc -x c - -o /tmp/csizeof && /tmp/csizeof
}

# bigfiles — show the largest files/directories under the current path.
# Uses dust (visual bar chart) if installed, falls back to du + sort.
# Usage: bigfiles
bigfiles() {
  if command -v dust &>/dev/null; then
    dust -n 20
  else
    du -ah . | sort -rh | head -20
  fi
}

# gclone — git clone + cd into the repo in one step.
# Saves the manual cd after cloning. Uses basename to strip .git suffix.
# Usage: gclone https://github.com/user/repo
#        gclone git@github.com:user/repo.git
gclone() { git clone "$1" && cd "$(basename "$1" .git)"; }


