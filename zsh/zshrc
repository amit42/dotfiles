# ── Stern — multi-pod log tailing ─────────────────────
# Unlike `kubectl logs`, stern can tail logs from multiple pods
# simultaneously, filtered by a regex. Essential for microservices.
# Usage: klogs-all "api-.*"               — all pods matching regex
#        klogs-all myapp -n production    — specific namespace
#        klogs-all myapp --since 10m      — only last 10 minutes
#        klogs-all myapp -o json          — JSON structured output
command -v stern &>/dev/null && alias klogs-all='stern'

# ── Helm — Kubernetes package manager ─────────────────
# Helm installs pre-packaged Kubernetes applications ("charts").
# Usage workflow:
#   hrepo                     — update chart index from all repos
#   hsr bitnami/postgresql    — search for a chart
#   hshow bitnami/postgresql  — inspect default values before install
#   hi my-db bitnami/postgresql --set auth.postgresPassword=secret
#   hls                       — verify it's running
if command -v helm &>/dev/null; then
  alias h='helm'
  alias hi='helm install'                   # install a new chart release
  alias hu='helm upgrade --install'         # upgrade, or install if not present (idempotent)
  alias hd='helm uninstall'                 # remove a chart release
  alias hls='helm list -A'                  # list all releases in all namespaces
  alias hrepo='helm repo update'            # fetch latest chart versions from all repos
  alias hsr='helm search repo'              # search repos: hsr postgresql
  alias hshow='helm show values'            # inspect a chart's default values: hshow bitnami/redis
  alias hdiff='helm diff upgrade'           # show what a helm upgrade would change (needs helm-diff plugin)
fi


