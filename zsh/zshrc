# cpy — copy to clipboard from argument or stdin.
# Detects whether it's being called interactively or in a pipe.
# Usage: cpy "some text"              — copy a string
#        cpy < file.txt               — copy file contents
#        curl api.example.com | cpy   — copy command output
cpy() {
  if [[ -t 0 ]]; then
    echo -n "$1" | pbcopy && echo "Copied."
  else
    pbcopy && echo "Copied from stdin."
  fi
}

