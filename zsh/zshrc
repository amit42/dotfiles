# STARSHIP PROMPT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# starship is a cross-shell prompt written in Rust.
# It shows: directory, git branch/status, language versions, exit code,
# command duration, and more — all configurable per-module.
#
# Config file: dotfiles/zsh/starship.toml → deployed to ~/.config/starship.toml
# Apply config changes: edit starship.toml → bash install.sh → open new terminal
# Docs: https://starship.rs/config/
#
# Must be initialised LAST — any prompt-modifying `eval` before this
# (thefuck, atuin) will be overwritten by starship's PS1.
if command -v starship &>/dev/null; then
  eval "$(starship init zsh)"
else
  print -P "%F{yellow}⚠ starship not found — run: brew install starship%f"
fi

# ── Profiling output ─────────────────────────────────────
# Must be the very last line — prints results after everything else loaded.
# Usage: ZSH_PROFILE=1 zsh     (open a new shell, see the ranked table)
[[ -n "$ZSH_PROFILE" ]] && zprof
