# LOG VIEWING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# lnav — Log Navigator. Auto-detects format (syslog, nginx, apache,
# JSON, journald) and renders it with syntax highlighting.
# Supports filtering, regex search, and SQL queries over log data.
# Install: brew install lnav
#
# Local usage:
#   log /var/log/nginx/access.log   — open in lnav TUI
#   log *.log                       — tail multiple files simultaneously
#   journalctl -f | lnav            — live systemd journal stream
#
# lnav keybindings (inside TUI):
#   /                       — regex search across visible lines
#   ;                       — SQL query mode: SELECT * FROM log WHERE level='error'
#   :filter-in <pattern>    — show only lines matching pattern
#   :filter-out <pattern>   — hide lines matching pattern
#   e / E                   — jump to next / previous error
#   TAB                     — cycle between open log files
#   q                       — quit
if command -v lnav &>/dev/null; then
  alias log='lnav'
else
  # Fallback when lnav isn't installed — bat still adds highlighting
  # for common log patterns (timestamps, ERROR/WARN/INFO levels).
  alias log='bat --paging=never --language=log'
fi

# sshlog — stream a remote log file into local lnav for rendering.
# The remote server only needs `tail -f` — no lnav installation needed there.
# All the rich TUI, filtering, and SQL query features work locally.
# Usage: sshlog user@prod-web /var/log/nginx/access.log
#        sshlog prod-db /var/log/postgresql/postgresql.log
sshlog() {
  if [[ $# -lt 2 ]]; then
    echo "Usage: sshlog <host> <logfile>"
    return 1
  fi
  ssh "$1" "tail -f $2" | lnav
}

# sshcat — view a remote log file once (no follow) with bat highlighting.
# Better than plain `ssh host cat file` because bat adds syntax colouring
# for log levels, timestamps, and stack traces.
# Usage: sshcat user@server /var/log/syslog
#        sshcat prod-db /var/log/app/error.log.2026-04-01
sshcat() {
  if [[ $# -lt 2 ]]; then
    echo "Usage: sshcat <host> <logfile>"
    return 1
  fi
  ssh "$1" "cat $2" | bat --language=log
}

# sshj — tail the systemd journal on a remote host into local lnav.
# Optionally filter to a single systemd unit (service name).
# Usage: sshj user@server              — all journal entries
#        sshj user@server nginx        — journal for nginx.service only
#        sshj prod-api myapp           — filter to myapp unit
sshj() {
  if [[ $# -lt 1 ]]; then
    echo "Usage: sshj <host> [unit]"
    return 1
  fi
  local unit_filter=""
  [[ -n "$2" ]] && unit_filter="-u $2"
  ssh "$1" "journalctl -f $unit_filter" | lnav
}


