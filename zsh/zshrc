#
# TOOL MAP (everything this file uses):
#   zinit       — plugin manager, self-bootstraps on first run
#   starship    — prompt (config: dotfiles/zsh/starship.toml)
#   fzf         — fuzzy finder (Ctrl+T files, Ctrl+R history, Alt+C cd)
#   fzf-tab     — replaces tab completion with fzf picker
#   eza         — modern ls with icons and git status
#   bat         — cat with syntax highlighting
#   delta       — beautiful git diffs (configured in git config)
#   lazygit     — full TUI git client (alias: lg)
#   zoxide      — smart cd that learns your dirs (alias: cd)
#   fd          — fast find replacement
#   rg          — fast grep replacement (ripgrep)
#   btop        — beautiful system monitor (alias: top)
#   tldr        — practical quick man pages
#   atuin       — shell history sync + fzf search (replaces Ctrl+R)
#   direnv      — per-directory env vars via .envrc files
#   thefuck     — corrects your last command (alias: fuck)
#   tmux        — terminal multiplexer, auto-attach on start

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ZINIT BOOTSTRAP
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Self-installs on first run — only needs git. No curl, no
# manual step. On subsequent runs just sources the loader.
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ ! -d "$ZINIT_HOME" ]]; then
  print -P "%F{yellow}→ Installing zinit...%f"
  mkdir -p "$(dirname "$ZINIT_HOME")"
  git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME" || {
    print -P "%F{red}✗ zinit clone failed — check network/git and re-open terminal%f"
    return 1
  }
fi
if [[ ! -f "${ZINIT_HOME}/zinit.zsh" ]]; then
  print -P "%F{red}✗ zinit.zsh missing — remove $ZINIT_HOME and re-open terminal%f"
  return 1
fi
source "${ZINIT_HOME}/zinit.zsh"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PLUGINS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Load order matters:
#   fzf-tab   — must come before autosuggestions/highlighting
#               replaces the default tab menu with a fzf picker
#   autosuggestions — ghost-text suggestions from history
#   completions     — extra completion definitions
#   fast-syntax-highlighting — real-time command coloring
#
# `wait lucid` = lazy-load after prompt paint — keeps startup fast.
zinit wait lucid light-mode for \
  Aloxaf/fzf-tab \
  zsh-users/zsh-autosuggestions \
  zsh-users/zsh-completions \
  zdharma-continuum/fast-syntax-highlighting

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# COMPLETIONS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
autoload -Uz compinit
compinit
zinit cdreplay -q   # replay completion fixes registered by plugins

# fzf-tab: show file previews when completing paths
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza --tree --level=1 --icons $realpath 2>/dev/null'
zstyle ':fzf-tab:complete:*' fzf-preview 'bat --color=always --line-range=:50 $realpath 2>/dev/null || eza --tree --level=1 --icons $realpath 2>/dev/null'

