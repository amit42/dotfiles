# Each block is guarded — falls back gracefully if tool not installed.

# bat — cat with syntax highlighting, line numbers, git markers
# --paging=never means it behaves like cat (no less pager) by default
if command -v bat &>/dev/null; then
  alias cat='bat --paging=never'
  alias catp='bat'                 # catp = cat with paging (for large files)
fi

# eza — ls replacement with icons, git status, tree view
if command -v eza &>/dev/null; then
  alias ls='eza --icons'
  alias ll='eza -lh --icons --git'
  alias la='eza -lah --icons --git'
  alias lt='eza --tree --icons --level=2'
else
  alias ls='ls --color=auto'
  alias ll='ls -lh --color=auto'
  alias la='ls -lah --color=auto'
fi

# rg — ripgrep, grep replacement (respects .gitignore, faster)
command -v rg &>/dev/null && alias grep='rg'

# fd — find replacement (simpler syntax, respects .gitignore)
command -v fd &>/dev/null && alias find='fd'

# btop — visual system monitor with CPU, mem, net, disk graphs
