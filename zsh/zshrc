alias kex='kubectl exec -it'                              # exec: kex <pod> -- ls /tmp
ksh()   { kubectl exec -it "$1" -- sh;   }                # open sh shell: ksh <pod>
kbash() { kubectl exec -it "$1" -- bash; }                # open bash shell: kbash <pod>

# ── Port forwarding ───────────────────────────────────
# kpf <pod-name> <port>   — forwards localhost:<port> → pod:<port>
# Example: kpf my-api-pod 8080
kpf() { kubectl port-forward "$1" "${2}:${2}"; }

# ── Deployment management ─────────────────────────────
alias krollout='kubectl rollout status deployment'        # watch rollout: krollout myapp
alias kscale='kubectl scale deployment'                   # scale: kscale myapp --replicas=3

