# ELITE TOOLS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# These tools hook into the shell via eval. They must load AFTER all
# aliases are defined (so they can wrap or extend them) and BEFORE
# the prompt (so they can modify PS1 if needed). The order here is
# also intentional: zoxide after direnv so the cd alias wins.

# zoxide — smarter cd that learns your directory visit frequency.
# After a few days of normal use, `z proj` jumps directly to
# ~/dev/my-project without typing the full path. The `cd` alias
# means existing muscle memory works unchanged — it just gets smarter.
# `zi` opens an fzf picker of your top directories if the query is ambiguous.
# Install: brew install zoxide
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh)"
  alias cd='z'   # z keeps the cd interface, adds frecency-based resolution
fi

# direnv — per-directory environment variable management.
# Create a .envrc in any project directory with your env vars:
#   echo 'export DATABASE_URL=postgres://localhost/mydb' > .envrc
#   direnv allow        — approve the file (one-time, per change)
# When you cd into the directory the vars are loaded; when you cd out
# they are unloaded. Works perfectly with uv, mise, and virtualenvs.
# Install: brew install direnv
if command -v direnv &>/dev/null; then
  eval "$(direnv hook zsh)"
fi

# thefuck — corrects your last mistyped command.
# Press Esc twice (or type `fuck`) to apply the suggested correction.
# Examples: `gti push` → `git push`   `got test` → `go test`
# Install: brew install thefuck
if command -v thefuck &>/dev/null; then
  eval "$(thefuck --alias)"
fi

# atuin — replaces the default Ctrl+R history search with a full-screen
# TUI showing timestamps, exit codes, and host (for sync setups).
# Optionally syncs history across machines via an atuin server (self-host
# or atuin.sh). History is stored encrypted end-to-end.
# Install: brew install atuin
# Setup sync: atuin register / atuin login / atuin sync
if command -v atuin &>/dev/null; then
