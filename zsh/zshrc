#
# ── Startup profiling ────────────────────────────────────
# To find out what's slow, start a shell with profiling on:
#   ZSH_PROFILE=1 zsh
# This prints a ranked breakdown of every function and how long
# it took. The output appears when the shell opens.
# zmodload must be the very first line to capture everything.
[[ -n "$ZSH_PROFILE" ]] && zmodload zsh/zprof
#
# HOW THIS FILE IS STRUCTURED
# ────────────────────────────────────────────────────────
# Load order is intentional — do not reorder sections:
#   1. Zinit bootstrap       — plugin manager must load first
#   2. Plugins               — loaded async (wait lucid) to keep startup fast
#   3. Completions           — must come after plugins register their completions
#   4. Environment           — exports and setopts used everywhere
#   5. Tool replacements     — alias modern tools over builtins
#   6. Alias sections        — grouped by domain
#   7. Functions / FZF       — interactive helpers
#   8. Elite tools           — tools that hook into the shell (eval-based)
#   9. Prompt (starship)     — must be last to not be overwritten
#
# TOOL MAP  (install: brew install <name> unless noted)
# ────────────────────────────────────────────────────────
#   zinit       — plugin manager, self-bootstraps on first run
#   starship    — prompt (config: dotfiles/zsh/starship.toml)
#   fzf         — fuzzy finder  Ctrl+T=files  Ctrl+R=history  Alt+C=cd
#   fzf-tab     — replaces zsh tab menu with an fzf picker
#   eza         — modern ls: icons, git-status, tree view
#   bat         — cat with syntax highlighting and git markers
#   delta       — beautiful git diffs  (configured in gitconfig, not here)
#   lazygit     — full TUI git client  (alias: lg)
#   zoxide      — smart cd that learns frequent dirs  (alias: cd)
#   fd          — fast find replacement  (respects .gitignore)
#   rg          — fast grep replacement  (ripgrep, respects .gitignore)
#   btop        — visual system monitor: CPU / mem / net / disk  (alias: top)
#   tldr        — practical quick-ref man pages  (alias: help)
#   atuin       — searchable shell history with timestamps  (replaces Ctrl+R)
#   direnv      — auto-loads .envrc on cd-in, unloads on cd-out
#   thefuck     — corrects your last command  (Esc Esc)
#   tmux        — terminal multiplexer
#   gh          — GitHub CLI: PRs, issues, CI runs, Copilot
#   k9s         — Kubernetes TUI  (alias: kk)
#   kubectx     — fast cluster/namespace switcher  (aliases: kctx, kns)
#   stern       — multi-pod Kubernetes log tailing  (alias: klogs-all)
#   helm        — Kubernetes package manager
#   uv          — fast Python package manager (replaces pip/venv/poetry)
#                 install: curl -LsSf https://astral.sh/uv/install.sh | sh
#   mise        — universal runtime version manager (node/python/go/ruby)
#                 replaces: pyenv, nvm, goenv, rbenv
#   yazi        — terminal file manager with cd-on-quit  (alias: ya)
#   navi        — interactive cheatsheet with fzf  (Ctrl+G)
#   jq          — JSON processor
#   yq          — YAML / JSON / TOML processor
#   hyperfine   — statistical command benchmarking  (alias: bench)
#   tokei       — lines-of-code counter by language  (alias: cloc)
#   just        — modern task runner / Makefile replacement  (alias: j)
#   duf         — modern df: disk usage grouped by type  (alias: df)
#   dust        — modern du: visual bar chart of disk usage  (alias: du)
#   procs       — modern ps: color output and process tree  (alias: ps)
#   xh          — modern HTTP client, httpie-compatible  (alias: http)
#   glow        — render Markdown in the terminal  (alias: md)
#   ouch        — universal archive tool, auto-detects format  (overrides extract)
#   sd          — friendly sed replacement, no backslash hell  (alias: sdr)
#   lnav        — log-file navigator with SQL query mode  (alias: log)
#   brew        — Homebrew package manager helpers
#   nmap        — port scanner  (used by portscan function)


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ZINIT BOOTSTRAP
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# zinit is the plugin manager used throughout this file.
# It self-installs on first run — no curl, no manual step.
# All it needs is git. On subsequent shells it just sources
# the loader (~2ms). Plugins are lazy-loaded via `wait lucid`
# so they never block prompt paint.
#
# If zinit gets corrupted: rm -rf ~/.local/share/zinit && reload.
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ ! -d "$ZINIT_HOME" ]]; then
  print -P "%F{yellow}→ Installing zinit...%f"
  mkdir -p "$(dirname "$ZINIT_HOME")"
  git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME" || {
    print -P "%F{red}✗ zinit clone failed — check network/git and re-open terminal%f"
    return 1
  }
fi
if [[ ! -f "${ZINIT_HOME}/zinit.zsh" ]]; then
  print -P "%F{red}✗ zinit.zsh missing — remove $ZINIT_HOME and re-open terminal%f"
  return 1
fi
source "${ZINIT_HOME}/zinit.zsh"


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PLUGINS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# All plugins use `wait lucid` — they load asynchronously
# AFTER the first prompt is painted, so shell startup is instant.
#
# Load order within this block matters:
#   fzf-tab                  — must load FIRST; hooks into zsh's
#                              completion system before other plugins
#                              register their handlers
#   zsh-autosuggestions      — fish-style ghost-text from history;
#                              appears right of cursor as you type
#   zsh-completions          — 600+ extra completion definitions for
#                              tools not in the zsh standard library
#   fast-syntax-highlighting — real-time command coloring:
#                              green=valid command, red=not found,
#                              yellow=aliases, blue=builtins
#   zsh-history-substring-search — Up/Down arrow history search
#                              filtered by the text already typed
#   zsh-you-should-use       — prints a reminder when you type a
#                              command that has a defined alias
# fast-syntax-highlighting must load AFTER zsh-history-substring-search.
# FSH wraps all ZLE widgets at load time — if history-substring-search
# hasn't registered its widgets yet, FSH doesn't know about them and
# prints "unhandled ZLE widget" warnings on every shell open.
# Splitting into two blocks guarantees the load order.
zinit wait lucid light-mode for \
  Aloxaf/fzf-tab \
  zsh-users/zsh-autosuggestions \
  zsh-users/zsh-completions \
  zsh-users/zsh-history-substring-search \
  MichaelAquilina/zsh-you-should-use

# FSH loads in a second wait block so history-substring-search widgets
# are already registered before FSH wraps them.
zinit wait lucid light-mode for \
  zdharma-continuum/fast-syntax-highlighting

# zsh-autosuggestions tuning
# BUFFER_MAX_SIZE: stop suggesting when line is longer than 20 chars
# — prevents lag when pasting multi-line content or editing long commands.
# STRATEGY: try history first (exact match), fall back to completion engine
# if no history entry matches the current prefix.
export ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20
export ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# zsh-history-substring-search keybindings
# Type any partial string (e.g. "docker") then press Up/Down to cycle
# ONLY through history entries that contain that string.
# Two escape sequences are bound per direction — different terminals
# send different codes for the arrow keys.
bindkey '^[[A' history-substring-search-up      # Up arrow
bindkey '^[[B' history-substring-search-down    # Down arrow
bindkey '^[OA' history-substring-search-up      # Up arrow (alt code)
bindkey '^[OB' history-substring-search-down    # Down arrow (alt code)

# zsh-you-should-use configuration
# YSU_MESSAGE_POSITION=after   — show the hint after the command runs,
#                                not before (less disruptive to flow)
# YSU_MODE=ALL                 — warn for both regular aliases AND
#                                global aliases (aliases that expand
#                                anywhere on the line, not just position 0)
export YSU_MESSAGE_POSITION="after"
export YSU_MODE=ALL


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# COMPLETIONS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# compinit scans all completion files and builds a dump (~/.zcompdump).
# That scan is slow. The optimisation here: run full compinit only
# when the dump is stale (older than today), and use `compinit -C`
# (skip the scan, trust the cache) on every other shell open.
#
# The date check uses %j (day-of-year, 1–366) so the cache refreshes
# once per calendar day regardless of time, and stat reads the dump's
# modification day in the same format for a direct comparison.
#
# zinit cdreplay replays any completion registration calls that plugins
# made BEFORE compinit ran (necessary because plugins load async).
autoload -Uz compinit
if [[ $(date +'%j') != "$(stat -f '%Sm' -t '%j' "$HOME/.zcompdump" 2>/dev/null)" ]]; then
  compinit        # full rebuild — checks all fpath entries for security
else
  compinit -C     # fast path — use cached dump, skip security scan
fi
zinit cdreplay -q

# fzf-tab preview configuration
# When you Tab-complete a `cd` argument, the right pane shows the
# directory tree one level deep using eza.
# For all other completions, the right pane shows a bat syntax-
# highlighted preview of the file (first 50 lines), falling back
# to an eza tree if the realpath is a directory.
zstyle ':fzf-tab:complete:cd:*' fzf-preview \
  'eza --tree --level=1 --icons $realpath 2>/dev/null'
zstyle ':fzf-tab:complete:*' fzf-preview \
  'bat --color=always --line-range=:50 $realpath 2>/dev/null || eza --tree --level=1 --icons $realpath 2>/dev/null'


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ENVIRONMENT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Default editor — used by git commit, crontab -e, etc.
export EDITOR="nvim"
export VISUAL="nvim"

# MANPAGER: pipe man output through col (strip backspace-bold) then bat.
# Result: man pages rendered with syntax highlighting and line numbers.
# -l man  = use man-page syntax definition
# -p      = plain style (no decorations, just highlighting)
export MANPAGER="sh -c 'col -bx | bat -l man -p'"

# LESS options applied whenever less is used as a pager:
# -R   pass raw ANSI escape codes through (needed for colour output)
# --quit-if-one-screen  exit immediately if content fits on screen
# --no-init  don't clear the screen when less exits (keeps output visible)
export LESS='-R --quit-if-one-screen --no-init'

# Locale — ensures consistent UTF-8 handling across all tools.
# Without this, some CLI tools (curl, git, python) can garble
# non-ASCII characters or behave differently per machine.
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# Docker BuildKit — enables the modern build backend:
# parallel stage execution, better caching, and inline cache export.
# COMPOSE_DOCKER_CLI_BUILD makes docker compose use the same backend.
export DOCKER_BUILDKIT=1
export COMPOSE_DOCKER_CLI_BUILD=1

# History — 100k entries kept both in memory and on disk.
# HISTFILE explicitly set so it's always in the same place regardless
# of whether $ZDOTDIR is customised.
export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=100000
export SAVEHIST=100000

# History options:
# EXTENDED_HISTORY     — prefix each entry with : <timestamp>:<elapsed>;
#                        used by atuin and `history -E` for time display
# INC_APPEND_HISTORY   — write each command immediately on execution,
#                        not only when the shell exits; prevents loss
#                        if the terminal crashes
# HIST_IGNORE_DUPS     — don't add a command if it's identical to the
#                        immediately preceding entry
# HIST_IGNORE_ALL_DUPS — go further: remove any older duplicate from
#                        the list, keeping only the most recent occurrence
# HIST_IGNORE_SPACE    — prefix a command with a space to skip recording
#                        it — useful for secrets: " export API_KEY=..."
# HIST_VERIFY          — when ! expansion is used, show the substituted
#                        command and wait for Enter before running
# SHARE_HISTORY        — all open terminals share the same history in
#                        real-time (new commands visible in other tabs
#                        immediately, not just on next shell start)
setopt EXTENDED_HISTORY
setopt INC_APPEND_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_VERIFY
setopt SHARE_HISTORY

# Shell behaviour:
# AUTO_CD   — type a directory name without `cd` to enter it
# CORRECT   — suggest a spelling correction for mistyped commands
setopt AUTO_CD
setopt CORRECT

# WORDCHARS controls which characters are treated as part of a "word"
# for Ctrl+W (delete word) and Ctrl+Left/Right (jump word).
# Removing / and . from the default set means those stop at path
# components, so Ctrl+W on "/usr/local/bin" deletes "bin", not the
# whole path. The remaining chars (*, ?, _, etc.) stay word-internal.
WORDCHARS='*?_-.[]~=&;!#$%^(){}<>'

# Ctrl+Left / Ctrl+Right — jump forward/backward one word.
# These are the ANSI escape sequences sent by most terminal emulators
# for Ctrl+arrow. If your terminal uses different codes, check with
# Ctrl+V then the key combination to see what it sends.
bindkey "^[[1;5C" forward-word
bindkey "^[[1;5D" backward-word


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MODERN TOOL REPLACEMENTS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Every block is guarded with `command -v` — if the tool isn't
# installed the alias is simply not set and the original command
# keeps working. Install any of these with: brew install <name>

# bat — cat with syntax highlighting, line numbers, and git-diff markers.
# --paging=never makes it behave like cat (no less pager) so it doesn't
# block in scripts or pipelines. Use `catp` when you want pagination.
if command -v bat &>/dev/null; then
  alias cat='bat --paging=never'  # syntax-highlighted cat, no pager
  alias catp='bat'                # cat with paging — good for large files
fi

# eza — modern ls built in Rust. Shows icons (needs a Nerd Font),
# git status per file, human-readable sizes, and colour by file type.
# Falls back to colour ls if eza isn't installed.
if command -v eza &>/dev/null; then
  alias ls='eza --icons'                   # basic listing with icons
  alias ll='eza -lh --icons --git'         # long format + git status column
  alias la='eza -lah --icons --git'        # long format + hidden files
  alias lt='eza --tree --icons --level=2'  # tree view 2 levels deep
else
  alias ls='ls --color=auto'
  alias ll='ls -lh --color=auto'
  alias la='ls -lah --color=auto'
fi

# rg (ripgrep) — grep replacement.
# 3–10× faster than grep, respects .gitignore automatically,
# searches binary files safely, and has better default output.
# Usage: grep "pattern" [path]   (same interface as grep)
command -v rg &>/dev/null && alias grep='rg'

# fd — find replacement.
# Simpler syntax, respects .gitignore, Unicode-aware, colour output.
# Usage: find "*.rs"             (vs find . -name "*.rs")
#        find -t d src           (find directories named src)
command -v fd &>/dev/null && alias find='fd'

# btop — terminal system monitor with graphs for CPU, memory,
# network I/O, and disk I/O. Replaces both top and htop.
# Keybindings inside btop: q=quit, f=filter, k=kill, m=mem sort
command -v btop &>/dev/null && alias top='btop'

# tldr — community-maintained practical man pages.
# Shows the 5–10 most common usage patterns instead of the full spec.
# Usage: help tar   help git   help ffmpeg
command -v tldr &>/dev/null && alias help='tldr'

# duf — modern df. Groups mount points by type (local, network, special)
# and shows colour-coded bars for used vs free space at a glance.
# Usage: df                 (overview of all filesystems)
#        df /home           (specific path)
command -v duf &>/dev/null && alias df='duf'

# dust — modern du. Draws a visual bar chart showing which directories
# are consuming the most space. Much faster than du on large trees.
# Usage: du                 (current directory)
#        du /var/log        (specific path)
#        du -n 10           (top 10 entries only)
command -v dust &>/dev/null && alias du='dust'

# procs — modern ps. Colour output, tree view of parent/child relations,
# and human-readable memory sizes. Supports fuzzy search by name.
# Usage: ps                 (all processes)
#        ps nginx           (filter to processes matching "nginx")
#        ps --tree          (show process tree)
command -v procs &>/dev/null && alias ps='procs'

# xh — modern HTTP client. httpie-compatible syntax but written in Rust,
# so it's significantly faster and has no Python dependency.
# Usage: http get httpbin.org/get
#        http post api.example.com/users name=alice age:=30
#        http -j get api.example.com    (JSON output only)
command -v xh &>/dev/null && alias http='xh'

# glow — render Markdown files beautifully in the terminal.
# Without an argument, opens a TUI browser of all .md files in the
# current directory. Useful for reading READMEs without leaving the terminal.
# Usage: md README.md       (render a specific file)
#        md                 (browse all .md files in current dir)
command -v glow &>/dev/null && alias md='glow'

# ouch — universal archive tool. Detects format from the file extension
# automatically — no flags needed. Supports .tar.gz, .zip, .7z, .rar,
# .bz2, .xz, .zst, and more. When installed it overrides the manual
# extract() case statement below (still kept as fallback).
# Usage: extract archive.tar.gz      (decompress)
#        compress src/ output.tar.gz  (compress)
if command -v ouch &>/dev/null; then
  extract() { ouch decompress "$@"; }
  alias compress='ouch compress'
fi

# sd — modern sed with cleaner regex syntax. Supports literal strings
# and regex without backslash-escaping every special character.
# Intentionally NOT aliased over `sed` — the syntax is different enough
# that scripts calling `sed` would break. Use `sdr` explicitly.
# Usage: sdr 'old text' 'new text' file.txt
#        sdr '(\w+) (\w+)' '$2 $1' file.txt   (capture groups)
command -v sd &>/dev/null && alias sdr='sd'


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GLOBAL ALIASES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Global aliases expand anywhere on the command line — not just at
# position 0. This makes them pipe-friendly postfix shortcuts.
# Usage: docker logs myapp L          (pipe into less)
#        kubectl get pods G Running   (grep through output)
#        cargo build NUL              (silence all output)
alias -g G='| grep'          # grep:   cmd G pattern
alias -g Gi='| grep -i'      # igrep:  cmd Gi pattern  (case-insensitive)
alias -g H='| head'          # head:   cmd H -20
alias -g T='| tail'          # tail:   cmd T -20
alias -g L='| less'          # page:   cmd L
alias -g C='| pbcopy'        # copy:   cmd C            (macOS clipboard)
alias -g P='| pbpaste'       # paste:  P | cmd
alias -g COUNT='| wc -l'     # count:  cmd COUNT
alias -g NUL='>/dev/null 2>&1' # silence: cmd NUL
alias -g J='| jq .'          # pretty JSON: curl api/endpoint J


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ALIASES: NAVIGATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Quick directory traversal. These complement AUTO_CD (which lets
# you type a directory name directly) and zoxide (which learns
# frequent paths so `z proj` jumps to ~/dev/my-project).
alias ..='cd ..'           # go up one level
alias ...='cd ../..'       # go up two levels
alias ~='cd ~'             # go to home directory
alias -- -='cd -'          # return to previous directory (cd toggle)

# up — go up N directory levels in one command.
# More readable than chains of ../../../
# Usage: up        → cd ..  (default 1)
#        up 3      → cd ../../..
#        up 5      → cd ../../../../..
up() {
  local d='' n="${1:-1}"
  for ((i=0; i<n; i++)); do d="../$d"; done
  cd "$d"
}

# tmpcd — create a throwaway temp directory and cd into it.
# Perfect for one-off experiments, building test files, or
# checking out a tool without polluting your workspace.
# The path is printed so you can reference it later.
# Usage: tmpcd
tmpcd() {
  local dir
  dir=$(mktemp -d)
  echo "→ $dir"
  cd "$dir"
}

# dot — jump straight to the dotfiles source directory.
# Usage: dot
alias dot='cd ~/Desktop/dotfiles/dotfiles'

# Auto-list after cd — runs `ls` every time you change directory.
# Uses the ls alias (eza with icons if installed) so the listing
# is always styled. Defined via add-zsh-hook so it stacks cleanly
# with other chpwd hooks (zoxide, direnv, etc.).
autoload -Uz add-zsh-hook
_auto_ls() { ls; }
add-zsh-hook chpwd _auto_ls


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ALIASES: EDITOR
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# All editor aliases point to nvim. `vi` and `vim` are overridden
# so muscle memory from older setups keeps working.
alias v='nvim'
alias vi='nvim'
alias vim='nvim'

# zshedit — open the zshrc source file directly in nvim.
# Points to the dotfiles source (not the deployed ~/.config copy)
# so edits go into version control automatically.
alias zshedit='nvim ~/Desktop/dotfiles/dotfiles/zsh/zshrc'

# Safer file operations — -i prompts before overwriting/deleting,
# -v prints what was done. Prevents accidental data loss.
# To bypass for scripting: \cp, \mv, \rm (backslash skips aliases).
alias cp='cp -iv'   # -i=interactive (prompt on overwrite) -v=verbose
alias mv='mv -iv'   # -i=interactive (prompt on overwrite) -v=verbose
alias rm='rm -iv'   # -i=interactive (prompt on delete)    -v=verbose

# vf — fuzzy-find a file and open it in nvim.
# Preview pane shows syntax-highlighted file content.
# Usage: vf              (search from current dir)
#        vf src/         (search within a subdirectory)
vf() {
  local file
  file=$(fd --type f --hidden --exclude .git "${1:-.}" | \
    fzf --preview 'bat --color=always --line-range=:80 {}')
  [[ -n "$file" ]] && nvim "$file"
}

# rgf — interactive ripgrep with live fzf preview, opens result in nvim.
# Type to search across file contents; the preview pane highlights the
# matching line in context. Press Enter to jump straight to that line.
# Usage: rgf "TODO"
#        rgf "fn main" src/
rgf() {
  rg --color=always --line-number --no-heading --smart-case "${*:-}" |
    fzf --ansi \
        --delimiter ':' \
        --preview 'bat --color=always {1} --highlight-line {2}' \
        --preview-window 'right:60%:border-left:+{2}+3/3' \
        --bind 'enter:become(nvim {1} +{2})'
}

# scratch — open a temporary scratch buffer in nvim.
# Useful for quick notes, drafting messages, or pasting something
# to inspect. File extension defaults to .md for markdown syntax.
# Usage: scratch          → /tmp/scratch.md
#        scratch py       → /tmp/scratch.py  (with Python highlighting)
#        scratch json     → /tmp/scratch.json
scratch() { nvim "/tmp/scratch.${1:-md}"; }


