alias gc='git commit -m'                                # commit with inline message: gc "msg"
alias gca='git commit --amend --no-edit'                # amend last commit, keep its message
alias gp='git push'                                     # push to tracked remote
alias gpf='git push --force-with-lease'                 # force-push but abort if remote has new commits
alias gl='git pull'                                     # pull (fetch + merge/rebase per config)
alias gco='git checkout'                                # checkout branch or file: gco main
alias gcb='git checkout -b'                             # create + switch to new branch: gcb feat/foo
