# PROMPT POSITIONING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Ctrl+L normally clears the screen and moves the prompt to the top.
# This binding instead pushes the prompt to the vertical MIDDLE of
# the terminal, printing blank lines above it. Previous output remains
# in the scrollback buffer — scroll up to see it. This gives breathing
# room without losing context, which is useful during long sessions.
_prompt_to_middle() {
  local half=$(( LINES / 2 ))
  printf '\n%.0s' {1..$half}
  zle reset-prompt
}
zle -N _prompt_to_middle
bindkey '^L' _prompt_to_middle


