# ╔═══════════════════════════════════════════════════════╗
# ║  .editorconfig                                       ║
# ║  Consistent formatting across all editors/IDEs.     ║
# ║  Supported by VS Code, JetBrains, Neovim, Vim, etc. ║
# ╚═══════════════════════════════════════════════════════╝

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Shell scripts
[*.{sh,zsh,bash}]
indent_style = space
indent_size = 2

# Lua (neovim, wezterm)
[*.lua]
indent_style = space
indent_size = 2

# Config files
[*.{toml,yaml,yml,json}]
indent_style = space
indent_size = 2

# Markdown — preserve trailing spaces (used for line breaks)
[*.md]
trim_trailing_whitespace = false

# Makefile — must use tabs
[Makefile]
indent_style = tab
